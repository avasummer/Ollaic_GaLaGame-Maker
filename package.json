{
  "name": "ollaic",
  "private": true,
  "version": "0.1.0",
  "scripts": {
    "dev": "pnpm --dir design dev",
    "build": "pnpm --dir design build",
    "preview": "pnpm --dir design preview",
    "test": "pnpm --dir design test && cargo test --manifest-path src-tauri/Cargo.toml",
    "test:ui": "pnpm --dir design test",
    "test:rust": "cargo test --manifest-path src-tauri/Cargo.toml",
    "e2e:web": "pnpm --dir design e2e:web",
    "verify": "pnpm build && pnpm test",
    "tauri": "tauri",
    "tauri:dev": "tauri dev",
    "tauri:build": "tauri build"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.10.1"
  },
  "pnpm": {
    "overrides": {
      "vite": "6.3.5"
    },
    "onlyBuiltDependencies": [
      "@tailwindcss/oxide",
      "esbuild"
    ]
  }
}
