{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Ollaic",
  "version": "0.1.0",
  "identifier": "com.ollaic.galagame-maker",
  "build": {
    "beforeDevCommand": "pnpm --dir design dev",
    "beforeBuildCommand": "pnpm --dir design build",
    "devUrl": "http://127.0.0.1:1420",
    "frontendDist": "../design/dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Ollaic GaLaGame Maker",
        "width": 1440,
        "height": 900,
        "minWidth": 1100,
        "minHeight": 720,
        "resizable": true,
        "dragDropEnabled": false
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": []
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": [
      "models/*.onnx"
    ],
    "macOS": {
      "signingIdentity": "-"
    }
  }
}
